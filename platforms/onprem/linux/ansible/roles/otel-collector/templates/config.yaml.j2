# =============================================================================
# OpenTelemetry Collector Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY
# Mode: {{ otel_mode }}
# Host: {{ ansible_hostname }}
# =============================================================================

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:${OTLP_GRPC_PORT:-4317}
      http:
        endpoint: 0.0.0.0:${OTLP_HTTP_PORT:-4318}

{% if otel_mode == 'agent' %}
  hostmetrics:
    collection_interval: {{ otel_hostmetrics_interval | default('30s') }}
    scrapers:
      cpu:
        metrics:
          system.cpu.utilization:
            enabled: true
      memory:
        metrics:
          system.memory.utilization:
            enabled: true
      disk:
        metrics:
          system.disk.io:
            enabled: true
          system.disk.operations:
            enabled: true
      filesystem:
        metrics:
          system.filesystem.utilization:
            enabled: true
        exclude_mount_points:
          mount_points:
            - /dev/*
            - /proc/*
            - /sys/*
            - /run/*
            - /snap/*
          match_type: regexp
      network:
        metrics:
          system.network.io:
            enabled: true
          system.network.connections:
            enabled: true
        exclude:
          interfaces:
            - lo
          match_type: strict
      process:
        metrics:
          process.cpu.utilization:
            enabled: true
          process.memory.usage:
            enabled: true
        mute_process_name_error: true
        mute_process_exe_error: true

  filelog:
    include:
{% for log_path in otel_log_paths | default(['/var/log/syslog', '/var/log/messages', '/var/log/auth.log']) %}
      - {{ log_path }}
{% endfor %}
    include_file_name: true
    include_file_path: true
    poll_interval: 500ms
    start_at: end

  journald:
    directory: /var/log/journal
    units:
{% for unit in otel_journald_units | default(['sshd', 'docker', 'otel-collector']) %}
      - {{ unit }}
{% endfor %}
    priority: info
    start_at: end

  syslog:
    tcp:
      listen_address: 0.0.0.0:${SYSLOG_TCP_PORT:-514}
    protocol: rfc5424
{% endif %}

processors:
{% if otel_mode == 'agent' %}
  resourcedetection:
    detectors:
      - system
    system:
      hostname_sources:
        - lookup
        - os
      resource_attributes:
        host.name:
          enabled: true
        host.id:
          enabled: true
        os.type:
          enabled: true
{% endif %}

  resource:
    attributes:
      - key: deployment.environment
        value: ${ENVIRONMENT:-{{ otel_environment | default('unknown') }}}
        action: upsert
      - key: team
        value: ${TEAM:-{{ otel_team | default('platform') }}}
        action: upsert
      - key: collector.type
        value: {{ otel_mode }}
        action: upsert

  batch:
{% if otel_mode == 'gateway' %}
    send_batch_size: {{ otel_batch_size | default(16384) }}
    send_batch_max_size: 32768
    timeout: {{ otel_batch_timeout | default('10s') }}
{% else %}
    send_batch_size: 8192
    send_batch_max_size: 16384
    timeout: 5s
{% endif %}

  memory_limiter:
    check_interval: 5s
    limit_mib: ${MEMORY_LIMIT_MIB:-{{ otel_memory_limit_mib | default(400) }}}
    spike_limit_mib: ${MEMORY_SPIKE_MIB:-{{ otel_memory_spike_mib | default(100) }}}

{% if otel_mode == 'gateway' %}
  tail_sampling:
    decision_wait: 30s
    num_traces: 100000
    expected_new_traces_per_sec: 1000
    policies:
      - name: composite-policy
        type: composite
        composite:
          max_total_spans_per_second: 5000
          policy_order:
            - always-sample-errors
            - always-sample-slow
            - rate-limit-default
          composite_sub_policy:
            - name: always-sample-errors
              type: status_code
              status_code:
                status_codes:
                  - ERROR
            - name: always-sample-slow
              type: latency
              latency:
                threshold_ms: 2000
            - name: rate-limit-default
              type: probabilistic
              probabilistic:
                sampling_percentage: ${SAMPLING_RATE:-{{ otel_sampling_rate | default(10) }}}
          rate_allocation:
            - policy: always-sample-errors
              percent: 40
            - policy: always-sample-slow
              percent: 30
            - policy: rate-limit-default
              percent: 30
{% endif %}

exporters:
  otlp:
{% if otel_mode == 'agent' %}
    endpoint: ${GATEWAY_ENDPOINT:-{{ otel_gateway_endpoint | default('gateway.internal:4317') }}}
{% else %}
    endpoint: ${BACKEND_OTLP_ENDPOINT:-{{ otel_backend_endpoint | default('backend.internal:4317') }}}
{% endif %}
    tls:
      insecure: ${OTLP_INSECURE:-true}
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_interval: 30s
      max_elapsed_time: 300s
    sending_queue:
      enabled: true
      num_consumers: {{ 10 if otel_mode == 'gateway' else 4 }}
      queue_size: {{ 5000 if otel_mode == 'gateway' else 1000 }}

  debug:
    verbosity: basic
    sampling_initial: 5
    sampling_thereafter: 200

extensions:
  health_check:
    endpoint: 0.0.0.0:13133
  zpages:
    endpoint: 0.0.0.0:55679

service:
  extensions:
    - health_check
    - zpages

  pipelines:
    traces:
      receivers:
        - otlp
      processors:
        - memory_limiter
{% if otel_mode == 'agent' %}
        - resourcedetection
{% endif %}
{% if otel_mode == 'gateway' %}
        - tail_sampling
{% endif %}
        - resource
        - batch
      exporters:
        - otlp

    metrics:
      receivers:
        - otlp
{% if otel_mode == 'agent' %}
        - hostmetrics
{% endif %}
      processors:
        - memory_limiter
{% if otel_mode == 'agent' %}
        - resourcedetection
{% endif %}
        - resource
        - batch
      exporters:
        - otlp

    logs:
      receivers:
        - otlp
{% if otel_mode == 'agent' %}
        - filelog
        - journald
        - syslog
{% endif %}
      processors:
        - memory_limiter
{% if otel_mode == 'agent' %}
        - resourcedetection
{% endif %}
        - resource
        - batch
      exporters:
        - otlp

  telemetry:
    logs:
      level: {{ otel_log_level | default('info') }}
    metrics:
      level: {{ 'detailed' if otel_mode == 'gateway' else 'basic' }}
      address: 0.0.0.0:8888
