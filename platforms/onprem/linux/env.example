# =============================================================================
# OpenTelemetry Collector - Environment Variables
# =============================================================================
# Copy this file to /etc/otel-collector/env and customize for your deployment.
#
# Usage:
#   cp env.example /etc/otel-collector/env
#   vi /etc/otel-collector/env
#   systemctl restart otel-collector-agent
# =============================================================================

# -----------------------------------------------------------------------------
# Common Settings (both agent and gateway)
# -----------------------------------------------------------------------------

# Deployment environment identifier
# Used as resource attribute: deployment.environment
ENVIRONMENT=production

# Owning team name
# Used as resource attribute: team
TEAM=platform

# Logical node/host name override (defaults to system hostname)
NODE_NAME=

# TLS configuration for OTLP exporters
# Set to "false" to enable TLS verification
OTLP_INSECURE=true

# -----------------------------------------------------------------------------
# Agent Mode Settings
# -----------------------------------------------------------------------------

# Gateway OTLP gRPC endpoint (required for agent mode)
# The agent forwards all telemetry to this gateway
GATEWAY_ENDPOINT=gateway.internal:4317

# OTLP receiver listen ports (for application-instrumented telemetry)
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318

# Syslog TCP receiver port
# Note: Binding to port 514 requires CAP_NET_BIND_SERVICE capability
SYSLOG_TCP_PORT=514

# Agent memory limits (in MiB)
# Should be lower than systemd MemoryMax (512M default)
MEMORY_LIMIT_MIB=400
MEMORY_SPIKE_MIB=100

# -----------------------------------------------------------------------------
# Gateway Mode Settings
# -----------------------------------------------------------------------------

# Backend OTLP gRPC endpoint (required for gateway mode)
# The gateway exports processed telemetry to this backend
BACKEND_OTLP_ENDPOINT=backend.internal:4317

# Gateway OTLP receiver listen ports
GATEWAY_OTLP_GRPC_PORT=4317
GATEWAY_OTLP_HTTP_PORT=4318

# Gateway memory limits (in MiB)
# Should be lower than systemd MemoryMax (4G default)
MEMORY_LIMIT_MIB=2048
MEMORY_SPIKE_MIB=512

# Trace sampling rate (percentage, 0-100)
# Only applies to traces that are not errors or high-latency
SAMPLING_RATE=10

# Batch processor settings
BATCH_TIMEOUT=10s
BATCH_SIZE=16384
