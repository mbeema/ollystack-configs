{
  "uid": "otel-collector-health",
  "title": "OTel Collector Health",
  "description": "Health monitoring dashboard for OpenTelemetry Collector instances",
  "tags": ["opentelemetry", "collector", "health"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(otelcol_process_uptime, job)",
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "allValue": ".*"
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(otelcol_process_uptime{job=~\"$job\"}, instance)",
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Collector Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 600 },
              { "color": "green", "value": 3600 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "otelcol_process_uptime{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory Usage (RSS)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "otelcol_process_memory_rss{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(otelcol_process_cpu_seconds{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Exporter Queue Size",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 900 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "otelcol_exporter_queue_size{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "{{exporter}} - {{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Received vs Exported Spans",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/Exported.*/" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(otelcol_receiver_accepted_spans{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "Received - {{receiver}} ({{instance}})",
          "refId": "A"
        },
        {
          "expr": "rate(otelcol_exporter_sent_spans{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "Exported - {{exporter}} ({{instance}})",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Received vs Exported Metrics",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/Exported.*/" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(otelcol_receiver_accepted_metric_points{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "Received - {{receiver}} ({{instance}})",
          "refId": "A"
        },
        {
          "expr": "rate(otelcol_exporter_sent_metric_points{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "Exported - {{exporter}} ({{instance}})",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "Received vs Exported Logs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/Exported.*/" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(otelcol_receiver_accepted_log_records{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "Received - {{receiver}} ({{instance}})",
          "refId": "A"
        },
        {
          "expr": "rate(otelcol_exporter_sent_log_records{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "Exported - {{exporter}} ({{instance}})",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Dropped Spans",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never"
          },
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(otelcol_processor_dropped_spans{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "{{processor}} ({{instance}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Dropped Metrics",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never"
          },
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(otelcol_processor_dropped_metric_points{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "{{processor}} ({{instance}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Dropped Logs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never"
          },
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(otelcol_processor_dropped_log_records{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "{{processor}} ({{instance}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Batch Send Size Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "bucketSize": "",
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "scheme",
        "legendPlacement": "bottom"
      },
      "targets": [
        {
          "expr": "rate(otelcol_processor_batch_batch_send_size_bucket{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 12,
      "title": "Export Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(otelcol_exporter_send_failed_spans{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "Spans - {{exporter}} ({{instance}})",
          "refId": "A"
        },
        {
          "expr": "rate(otelcol_exporter_send_failed_metric_points{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "Metrics - {{exporter}} ({{instance}})",
          "refId": "B"
        },
        {
          "expr": "rate(otelcol_exporter_send_failed_log_records{job=~\"$job\", instance=~\"$instance\"}[5m])",
          "legendFormat": "Logs - {{exporter}} ({{instance}})",
          "refId": "C"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "links": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
