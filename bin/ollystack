#!/usr/bin/env bash
# ============================================================================
# OllyStack CLI - OpenTelemetry Collector Configuration Generator
# ============================================================================
# Compose production-ready OTel Collector configs from the OllyStack
# fragment library.
#
# Prerequisites:
#   - yq v4+ (https://github.com/mikefarah/yq)
#   - bash 4+ (for associative arrays)
#
# Usage:
#   ollystack init                    Interactive config wizard
#   ollystack list [category]         List available fragments
#   ollystack merge -o out.yaml f1.yaml f2.yaml ...
#   ollystack validate config.yaml    Validate YAML syntax
#   ollystack golden [config-name]    Copy a golden config
# ============================================================================

set -euo pipefail

# ── Globals ────────────────────────────────────────────────────────────────
VERSION="1.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
FRAGMENTS_DIR="${SCRIPT_DIR}/collector/fragments"
BASE_DIR="${SCRIPT_DIR}/collector/base"
GOLDEN_DIR="${SCRIPT_DIR}/golden-configs"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ── Helpers ────────────────────────────────────────────────────────────────
info()  { echo -e "${BLUE}[info]${NC}  $*"; }
ok()    { echo -e "${GREEN}[ok]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[warn]${NC}  $*"; }
err()   { echo -e "${RED}[error]${NC} $*" >&2; }
die()   { err "$@"; exit 1; }

check_deps() {
  command -v yq &>/dev/null || die "yq is required but not installed. Install: https://github.com/mikefarah/yq"
}

# ── cmd_list ───────────────────────────────────────────────────────────────
cmd_list() {
  local category="${1:-all}"

  echo -e "\n${BOLD}OllyStack Fragment Library${NC}\n"

  local categories=("receivers" "processors" "exporters" "extensions" "connectors")

  for cat in "${categories[@]}"; do
    if [[ "$category" != "all" && "$category" != "$cat" ]]; then
      continue
    fi

    local dir="${FRAGMENTS_DIR}/${cat}"
    if [[ ! -d "$dir" ]]; then
      continue
    fi

    local count
    count=$(find "$dir" -name '*.yaml' -o -name '*.yml' | wc -l | tr -d ' ')
    echo -e "${CYAN}${cat}${NC} (${count} fragments):"

    for f in "$dir"/*.yaml "$dir"/*.yml; do
      [[ -f "$f" ]] || continue
      local name
      name=$(basename "$f" .yaml)
      name=$(basename "$name" .yml)
      # Extract first comment line as description
      local desc
      desc=$(head -1 "$f" | sed 's/^#\s*//')
      printf "  %-40s %s\n" "$name" "$desc"
    done
    echo
  done

  # Also list golden configs
  if [[ "$category" == "all" || "$category" == "golden" ]]; then
    echo -e "${CYAN}golden-configs${NC}:"
    for f in "$GOLDEN_DIR"/*.yaml "$GOLDEN_DIR"/*.yml; do
      [[ -f "$f" ]] || continue
      local name
      name=$(basename "$f")
      printf "  %s\n" "$name"
    done
    echo
  fi
}

# ── cmd_merge ──────────────────────────────────────────────────────────────
cmd_merge() {
  local output=""
  local files=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -o|--output) output="$2"; shift 2 ;;
      -h|--help) echo "Usage: ollystack merge -o output.yaml file1.yaml file2.yaml ..."; exit 0 ;;
      *) files+=("$1"); shift ;;
    esac
  done

  [[ ${#files[@]} -lt 2 ]] && die "At least 2 files required for merge"

  # Verify all files exist
  for f in "${files[@]}"; do
    [[ -f "$f" ]] || die "File not found: $f"
  done

  info "Merging ${#files[@]} files..."

  local result
  result=$(cat "${files[0]}")

  for ((i=1; i<${#files[@]}; i++)); do
    # shellcheck disable=SC2016
    result=$(echo "$result" | yq eval-all '. as $item ireduce ({}; . *+ $item)' - "${files[$i]}")
  done

  if [[ -n "$output" ]]; then
    echo "$result" > "$output"
    ok "Merged config written to ${output}"
  else
    echo "$result"
  fi
}

# ── cmd_validate ───────────────────────────────────────────────────────────
cmd_validate() {
  local file="${1:-}"
  [[ -z "$file" ]] && die "Usage: ollystack validate <config.yaml>"
  [[ -f "$file" ]] || die "File not found: $file"

  info "Validating ${file}..."

  # Step 1: YAML syntax check with yq
  if yq eval '.' "$file" > /dev/null 2>&1; then
    ok "YAML syntax valid"
  else
    err "YAML syntax error:"
    yq eval '.' "$file"
    exit 1
  fi

  # Step 2: Check required top-level keys
  local has_receivers has_exporters has_service
  has_receivers=$(yq eval '.receivers | length' "$file")
  has_exporters=$(yq eval '.exporters | length' "$file")
  has_service=$(yq eval '.service | length' "$file")

  if [[ "$has_receivers" -gt 0 ]]; then
    ok "receivers: found"
  else
    warn "receivers: missing"
  fi
  if [[ "$has_exporters" -gt 0 ]]; then
    ok "exporters: found"
  else
    warn "exporters: missing"
  fi
  if [[ "$has_service" -gt 0 ]]; then
    ok "service: found"
  else
    warn "service: missing"
  fi

  # Step 3: Check service.pipelines
  local has_pipelines
  has_pipelines=$(yq eval '.service.pipelines | length' "$file")
  if [[ "$has_pipelines" -gt 0 ]]; then
    ok "service.pipelines: found (${has_pipelines} pipelines)"
  else
    warn "service.pipelines: missing"
  fi

  # Step 4: Check memory_limiter is first processor
  for pipeline in $(yq eval '.service.pipelines | keys | .[]' "$file" 2>/dev/null); do
    local first_proc
    first_proc=$(yq eval ".service.pipelines.${pipeline}.processors[0]" "$file" 2>/dev/null)
    if [[ "$first_proc" == "memory_limiter" ]]; then
      ok "pipeline/${pipeline}: memory_limiter is first processor"
    elif [[ "$first_proc" != "null" && "$first_proc" != "" ]]; then
      warn "pipeline/${pipeline}: first processor is '${first_proc}' (recommend memory_limiter)"
    fi
  done

  # Step 5: Try otelcol validate if available
  if command -v otelcol &>/dev/null; then
    info "Running otelcol validate..."
    if otelcol validate --config="$file" 2>&1; then
      ok "otelcol validation passed"
    else
      warn "otelcol validation failed (config may still be usable as a fragment)"
    fi
  fi

  echo
  ok "Validation complete for ${file}"
}

# ── cmd_golden ─────────────────────────────────────────────────────────────
cmd_golden() {
  local name="${1:-}"

  if [[ -z "$name" ]]; then
    echo -e "\n${BOLD}Available Golden Configs:${NC}\n"
    for f in "$GOLDEN_DIR"/*.yaml "$GOLDEN_DIR"/*.yml; do
      [[ -f "$f" ]] || continue
      local basename
      basename=$(basename "$f")
      # Extract description from header
      local desc
      desc=$(grep -m1 "^# Backend:" "$f" 2>/dev/null | sed 's/^#\s*Backend:\s*//' || echo "")
      printf "  %-45s %s\n" "$basename" "$desc"
    done
    echo
    echo "Usage: ollystack golden <config-name> [output-path]"
    return
  fi

  # Find the golden config
  local src=""
  for ext in yaml yml; do
    if [[ -f "${GOLDEN_DIR}/${name}" ]]; then
      src="${GOLDEN_DIR}/${name}"
      break
    elif [[ -f "${GOLDEN_DIR}/${name}.${ext}" ]]; then
      src="${GOLDEN_DIR}/${name}.${ext}"
      break
    fi
  done

  [[ -z "$src" ]] && die "Golden config not found: ${name}"

  local dest="${2:-otelcol-config.yaml}"
  cp "$src" "$dest"
  ok "Golden config copied to ${dest}"
  info "Edit ${dest} and set required environment variables before deploying."
}

# ── cmd_init ───────────────────────────────────────────────────────────────
cmd_init() {
  echo -e "\n${BOLD}OllyStack Config Generator${NC}"
  echo -e "Interactive wizard to compose an OpenTelemetry Collector config.\n"

  # Step 1: Platform
  echo -e "${CYAN}Step 1: Select Platform${NC}"
  local platforms=("aws" "azure" "gcp" "kubernetes" "onprem")
  select platform in "${platforms[@]}"; do
    [[ -n "$platform" ]] && break
    echo "Invalid selection, try again."
  done
  info "Platform: ${platform}"

  # Step 2: Backend
  echo -e "\n${CYAN}Step 2: Select Backend${NC}"
  local backends=("datadog" "splunk" "newrelic" "dynatrace" "elastic" "grafana-cloud" "aws-native" "azure-native" "gcp-native" "grafana-lgtm" "signoz" "victoriametrics" "uptrace" "openobserve" "jaeger-prometheus" "chronosphere" "axiom" "appdynamics" "instana" "servicenow")
  select backend in "${backends[@]}"; do
    [[ -n "$backend" ]] && break
    echo "Invalid selection, try again."
  done
  info "Backend: ${backend}"

  # Step 3: Signals
  echo -e "\n${CYAN}Step 3: Select Signals (enter numbers separated by spaces)${NC}"
  local selected_signals=()
  echo "1) traces"
  echo "2) metrics"
  echo "3) logs"
  read -rp "Select signals [1 2 3]: " signal_input
  signal_input="${signal_input:-1 2 3}"
  for num in $signal_input; do
    case "$num" in
      1) selected_signals+=("traces") ;;
      2) selected_signals+=("metrics") ;;
      3) selected_signals+=("logs") ;;
    esac
  done
  info "Signals: ${selected_signals[*]}"

  # Step 4: Environment
  echo -e "\n${CYAN}Step 4: Select Environment${NC}"
  local envs=("production" "staging" "development")
  select environment in "${envs[@]}"; do
    [[ -n "$environment" ]] && break
    echo "Invalid selection, try again."
  done
  info "Environment: ${environment}"

  # Step 5: Output file
  read -rp "Output file [otelcol-config.yaml]: " output_file
  output_file="${output_file:-otelcol-config.yaml}"

  # ── Build the config ──
  info "Composing config..."

  local merge_files=()

  # Base config
  merge_files+=("${BASE_DIR}/otel-agent-base.yaml")

  # Receivers
  merge_files+=("${FRAGMENTS_DIR}/receivers/otlp.yaml")
  if [[ "$platform" != "onprem" ]]; then
    [[ -f "${FRAGMENTS_DIR}/receivers/k8s-cluster.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/receivers/k8s-cluster.yaml")
    [[ -f "${FRAGMENTS_DIR}/receivers/kubeletstats.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/receivers/kubeletstats.yaml")
  fi
  merge_files+=("${FRAGMENTS_DIR}/receivers/hostmetrics.yaml")

  # Processors - always include core
  merge_files+=("${FRAGMENTS_DIR}/processors/memory-limiter.yaml")

  # Platform-specific resource detection
  case "$platform" in
    aws)   [[ -f "${FRAGMENTS_DIR}/processors/resourcedetection-aws.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/resourcedetection-aws.yaml") ;;
    azure) [[ -f "${FRAGMENTS_DIR}/processors/resourcedetection-azure.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/resourcedetection-azure.yaml") ;;
    gcp)   [[ -f "${FRAGMENTS_DIR}/processors/resourcedetection-gcp.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/resourcedetection-gcp.yaml") ;;
    *)     [[ -f "${FRAGMENTS_DIR}/processors/resourcedetection-system.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/resourcedetection-system.yaml") ;;
  esac

  # K8s attributes (if not onprem)
  if [[ "$platform" != "onprem" ]]; then
    [[ -f "${FRAGMENTS_DIR}/processors/k8sattributes.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/k8sattributes.yaml")
  fi

  # Cost optimization based on environment
  case "$environment" in
    production)
      [[ -f "${FRAGMENTS_DIR}/processors/filter-logs-severity.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/filter-logs-severity.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/filter-logs.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/filter-logs.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/filter-traces.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/filter-traces.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/filter-traces-noisy.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/filter-traces-noisy.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/transform-traces-cost.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/transform-traces-cost.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/filter-metrics-cardinality.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/filter-metrics-cardinality.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/tail-sampling-composite.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/tail-sampling-composite.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/redaction.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/redaction.yaml")
      ;;
    staging)
      [[ -f "${FRAGMENTS_DIR}/processors/filter-logs-severity.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/filter-logs-severity.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/filter-logs.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/filter-logs.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/filter-traces.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/filter-traces.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/filter-traces-noisy.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/filter-traces-noisy.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/filter-metrics-cardinality.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/filter-metrics-cardinality.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/probabilistic-sampling-head.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/probabilistic-sampling-head.yaml")
      ;;
    development)
      [[ -f "${FRAGMENTS_DIR}/processors/filter-logs.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/filter-logs.yaml")
      [[ -f "${FRAGMENTS_DIR}/processors/filter-traces.yaml" ]] && merge_files+=("${FRAGMENTS_DIR}/processors/filter-traces.yaml")
      ;;
  esac

  # Batch always last
  merge_files+=("${FRAGMENTS_DIR}/processors/batch.yaml")

  # Exporter - based on backend
  local exporter_fragment=""
  case "$backend" in
    datadog)           exporter_fragment="datadog.yaml" ;;
    splunk)            exporter_fragment="splunkhec.yaml" ;;
    newrelic)          exporter_fragment="otlp-http.yaml" ;;
    dynatrace)        exporter_fragment="otlp-http.yaml" ;;
    elastic)          exporter_fragment="otlp-http.yaml" ;;
    grafana-cloud)    exporter_fragment="otlp-http.yaml" ;;
    aws-native)       exporter_fragment="awsxray.yaml" ;;
    azure-native)     exporter_fragment="azuremonitor.yaml" ;;
    gcp-native)       exporter_fragment="googlecloud.yaml" ;;
    grafana-lgtm)     exporter_fragment="otlp-grpc.yaml" ;;
    signoz)           exporter_fragment="otlp-grpc.yaml" ;;
    *)                exporter_fragment="otlp-grpc.yaml" ;;
  esac
  [[ -f "${FRAGMENTS_DIR}/exporters/${exporter_fragment}" ]] && merge_files+=("${FRAGMENTS_DIR}/exporters/${exporter_fragment}")

  # Merge all files
  info "Merging ${#merge_files[@]} fragments..."

  local result
  result=$(cat "${merge_files[0]}")
  for ((i=1; i<${#merge_files[@]}; i++)); do
    if [[ -f "${merge_files[$i]}" ]]; then
      # shellcheck disable=SC2016
      result=$(echo "$result" | yq eval-all '. as $item ireduce ({}; . *+ $item)' - "${merge_files[$i]}")
    fi
  done

  echo "$result" > "$output_file"

  echo
  ok "Config generated: ${output_file}"
  info "Fragments merged: ${#merge_files[@]}"
  info "Platform: ${platform} | Backend: ${backend} | Environment: ${environment}"
  echo
  info "Next steps:"
  echo "  1. Set required environment variables for your backend"
  echo "  2. Review and customize: ${output_file}"
  echo "  3. Validate: ollystack validate ${output_file}"
  echo "  4. Deploy: otelcol --config=${output_file}"
}

# ── cmd_help ───────────────────────────────────────────────────────────────
cmd_help() {
  cat <<EOF

${BOLD}OllyStack CLI v${VERSION}${NC}
OpenTelemetry Collector Configuration Generator

${BOLD}USAGE:${NC}
  ollystack <command> [options]

${BOLD}COMMANDS:${NC}
  init                    Interactive wizard to generate a config
  list [category]         List available fragments (receivers|processors|exporters|extensions|connectors|golden|all)
  merge -o out.yaml ...   Merge multiple YAML fragments into one config
  validate <config.yaml>  Validate config syntax and structure
  golden [name] [output]  Copy a golden config as starting point
  help                    Show this help message
  version                 Show version

${BOLD}EXAMPLES:${NC}
  ollystack init                                    # Start interactive wizard
  ollystack list receivers                           # List all receiver fragments
  ollystack golden aws-datadog-production.yaml       # Start from a golden config
  ollystack merge -o config.yaml base.yaml otlp.yaml batch.yaml
  ollystack validate my-config.yaml

${BOLD}PREREQUISITES:${NC}
  - yq v4+ (https://github.com/mikefarah/yq)

EOF
}

cmd_version() {
  echo "ollystack v${VERSION}"
}

# ── Main ───────────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)     check_deps; cmd_init "$@" ;;
    list)     cmd_list "$@" ;;
    merge)    check_deps; cmd_merge "$@" ;;
    validate) check_deps; cmd_validate "$@" ;;
    golden)   cmd_golden "$@" ;;
    help|-h|--help) cmd_help ;;
    version|-v|--version) cmd_version ;;
    *)        err "Unknown command: ${cmd}"; cmd_help; exit 1 ;;
  esac
}

main "$@"
